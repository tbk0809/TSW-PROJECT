cds:Patient_002
    a                       cds:Patient ;
    cds:patientName         "Sara"^^xsd:string ;
    cds:patientAge          40 ;
    cds:patientID           "P002"^^xsd:string ;
    cds:hasSymptom          cds:Fever ,
                            cds:Cough ,
                            cds:ShortnessOfBreath ;
    cds:diagnosedWith       cds:Pneumonia ;
    cds:prescribedMedication cds:Amoxicillin ;
    cds:hasRiskLevel        cds:HighRisk_Instance ;
    cds:hasLabResult        cds:LabResult_002 ;
    cds:hasClinicalRecord   cds:ClinicalRecord_002 .

