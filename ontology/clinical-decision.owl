    <owl:NamedIndividual rdf:about="&cds;Hypertension">
        <rdf:type rdf:resource="&cds;Disease"/>
        <cds:diseaseName rdf:datatype="&xsd;string">Hypertension</cds:diseaseName>
        <!-- INFERENCE RULE 8 demo: Transitive chain starts here -->
        <cds:isRelatedConditionOf rdf:resource="&cds;CoronaryArteryDisease"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;Pneumonia">
        <rdf:type rdf:resource="&cds;Disease"/>
        <cds:diseaseName rdf:datatype="&xsd;string">Pneumonia</cds:diseaseName>
