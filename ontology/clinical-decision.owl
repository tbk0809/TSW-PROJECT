    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;CoronaryArteryDisease">
        <rdf:type rdf:resource="&cds;Disease"/>
        <cds:diseaseName rdf:datatype="&xsd;string">Coronary Artery Disease</cds:diseaseName>
        <!-- Transitive chain continues: CAD isRelatedConditionOf HeartFailure -->
        <cds:isRelatedConditionOf rdf:resource="&cds;HeartFailure"/>
    </owl:NamedIndividual>

    <!-- HeartFailure: end of transitive chain
         Reasoner infers: Hypertension isRelatedConditionOf HeartFailure (via transitivity) -->
    <owl:NamedIndividual rdf:about="&cds;HeartFailure">
        <rdf:type rdf:resource="&cds;Disease"/>
        <cds:diseaseName rdf:datatype="&xsd;string">Heart Failure</cds:diseaseName>
