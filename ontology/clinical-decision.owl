    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;LabResult_002">
        <rdf:type rdf:resource="&cds;LabResult"/>
        <cds:testName rdf:datatype="&xsd;string">Blood Sugar</cds:testName>
        <cds:testValue rdf:datatype="&xsd;float">250.0</cds:testValue>
    </owl:NamedIndividual>

    <!-- =============================================================== -->
    <!-- Individuals: Doctors                                            -->
    <!-- =============================================================== -->

    <!--
        INFERENCE RULE 6 demo: Property Chain
        Dr_Smith treatsPatient Patient_001 and Patient_001 diagnosedWith Hypertension.
        The reasoner infers: Dr_Smith isSpecialistFor Hypertension.
    -->
    <owl:NamedIndividual rdf:about="&cds;Dr_Smith">
        <rdf:type rdf:resource="&cds;Doctor"/>
        <cds:treatsPatient rdf:resource="&cds;Patient_001"/>
    </owl:NamedIndividual>

    <!--
        Dr_Jones treatsPatient Patient_002 and Patient_002 diagnosedWith Pneumonia.
        The reasoner infers: Dr_Jones isSpecialistFor Pneumonia.
    -->
    <owl:NamedIndividual rdf:about="&cds;Dr_Jones">
        <rdf:type rdf:resource="&cds;Doctor"/>
        <cds:treatsPatient rdf:resource="&cds;Patient_002"/>
    </owl:NamedIndividual>

    <!-- =============================================================== -->
    <!-- Individuals: Patients (5 in OWL file)                           -->
    <!-- =============================================================== -->

    <!--
        Patient_001: Ahmed, age 55
        Has 3 symptoms → will be inferred as HighRiskPatient (Rule 2),
        ComplexCase (Rule 5), and DiagnosedPatient (Rule 3).
        INFERENCE RULE 10 demo: prescribedMedication Amlodipine →
        reasoner infers Amlodipine prescribedTo Patient_001 (inverse).
    -->
    <owl:NamedIndividual rdf:about="&cds;Patient_001">
        <rdf:type rdf:resource="&cds;Patient"/>
        <cds:patientName rdf:datatype="&xsd;string">Ahmed</cds:patientName>
        <cds:patientAge rdf:datatype="&xsd;integer">55</cds:patientAge>
        <cds:patientID rdf:datatype="&xsd;string">P001</cds:patientID>
        <cds:hasSymptom rdf:resource="&cds;Headache"/>
        <cds:hasSymptom rdf:resource="&cds;Dizziness"/>
        <cds:hasSymptom rdf:resource="&cds;Hypertension_Symptom"/>
        <cds:diagnosedWith rdf:resource="&cds;Hypertension"/>
        <cds:prescribedMedication rdf:resource="&cds;Amlodipine"/>
        <cds:hasRiskLevel rdf:resource="&cds;HighRisk_Instance"/>
        <cds:hasLabResult rdf:resource="&cds;LabResult_001"/>
    </owl:NamedIndividual>

    <!--
        Patient_002: Sara, age 40
        Has 3 symptoms → inferred as HighRiskPatient, ComplexCase, DiagnosedPatient.
    -->
    <owl:NamedIndividual rdf:about="&cds;Patient_002">
        <rdf:type rdf:resource="&cds;Patient"/>
        <cds:patientName rdf:datatype="&xsd;string">Sara</cds:patientName>
        <cds:patientAge rdf:datatype="&xsd;integer">40</cds:patientAge>
        <cds:patientID rdf:datatype="&xsd;string">P002</cds:patientID>
        <cds:hasSymptom rdf:resource="&cds;Fever"/>
        <cds:hasSymptom rdf:resource="&cds;Cough"/>
        <cds:hasSymptom rdf:resource="&cds;ShortnessOfBreath"/>
        <cds:diagnosedWith rdf:resource="&cds;Pneumonia"/>
        <cds:prescribedMedication rdf:resource="&cds;Amoxicillin"/>
        <cds:hasRiskLevel rdf:resource="&cds;HighRisk_Instance"/>
    </owl:NamedIndividual>

    <!--
        Patient_003: John, age 62
        Has 3 symptoms → inferred as HighRiskPatient, ComplexCase, DiagnosedPatient.
    -->
    <owl:NamedIndividual rdf:about="&cds;Patient_003">
        <rdf:type rdf:resource="&cds;Patient"/>
        <cds:patientName rdf:datatype="&xsd;string">John</cds:patientName>
        <cds:patientAge rdf:datatype="&xsd;integer">62</cds:patientAge>
        <cds:patientID rdf:datatype="&xsd;string">P003</cds:patientID>
        <cds:hasSymptom rdf:resource="&cds;Fatigue"/>
        <cds:hasSymptom rdf:resource="&cds;FrequentUrination"/>
        <cds:hasSymptom rdf:resource="&cds;BlurredVision"/>
        <cds:diagnosedWith rdf:resource="&cds;Type2Diabetes"/>
        <cds:prescribedMedication rdf:resource="&cds;Metformin"/>
        <cds:hasRiskLevel rdf:resource="&cds;MediumRisk_Instance"/>
    </owl:NamedIndividual>

    <!--
        Patient_004: Maria, age 70
        Has 2 symptoms → inferred as ComplexCase (Rule 5) and DiagnosedPatient (Rule 3).
        NOT HighRiskPatient (needs min 3 symptoms).
    -->
    <owl:NamedIndividual rdf:about="&cds;Patient_004">
        <rdf:type rdf:resource="&cds;Patient"/>
        <cds:patientName rdf:datatype="&xsd;string">Maria</cds:patientName>
        <cds:patientAge rdf:datatype="&xsd;integer">70</cds:patientAge>
        <cds:patientID rdf:datatype="&xsd;string">P004</cds:patientID>
        <cds:hasSymptom rdf:resource="&cds;ChestPain"/>
        <cds:hasSymptom rdf:resource="&cds;ShortnessOfBreath"/>
        <cds:diagnosedWith rdf:resource="&cds;CoronaryArteryDisease"/>
        <cds:prescribedMedication rdf:resource="&cds;Aspirin"/>
        <cds:hasRiskLevel rdf:resource="&cds;HighRisk_Instance"/>
    </owl:NamedIndividual>

    <!--
        Patient_005: Ali, age 28
        Has 2 symptoms → inferred as ComplexCase and DiagnosedPatient.
    -->
    <owl:NamedIndividual rdf:about="&cds;Patient_005">
        <rdf:type rdf:resource="&cds;Patient"/>
        <cds:patientName rdf:datatype="&xsd;string">Ali</cds:patientName>
        <cds:patientAge rdf:datatype="&xsd;integer">28</cds:patientAge>
        <cds:patientID rdf:datatype="&xsd;string">P005</cds:patientID>
        <cds:hasSymptom rdf:resource="&cds;Rash"/>
        <cds:hasSymptom rdf:resource="&cds;Itching"/>
        <cds:diagnosedWith rdf:resource="&cds;AllergicReaction"/>
        <cds:prescribedMedication rdf:resource="&cds;Antihistamine"/>
        <cds:hasRiskLevel rdf:resource="&cds;LowRisk_Instance"/>
    </owl:NamedIndividual>

    <!-- =============================================================== -->
    <!-- Symptom-Disease indicatesDisease Relations                      -->
