    <!-- =============================================================== -->
    <!-- Individuals: Medications (9 total)                              -->
    <!-- =============================================================== -->

    <owl:NamedIndividual rdf:about="&cds;Amlodipine">
        <rdf:type rdf:resource="&cds;Medication"/>
        <cds:medicationName rdf:datatype="&xsd;string">Amlodipine</cds:medicationName>
        <cds:dosage rdf:datatype="&xsd;string">5mg daily</cds:dosage>
        <cds:treatsDisease rdf:resource="&cds;Hypertension"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;Amoxicillin">
        <rdf:type rdf:resource="&cds;Medication"/>
        <cds:medicationName rdf:datatype="&xsd;string">Amoxicillin</cds:medicationName>
        <cds:dosage rdf:datatype="&xsd;string">500mg three times daily</cds:dosage>
        <cds:treatsDisease rdf:resource="&cds;Pneumonia"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;Metformin">
        <rdf:type rdf:resource="&cds;Medication"/>
        <cds:medicationName rdf:datatype="&xsd;string">Metformin</cds:medicationName>
        <cds:dosage rdf:datatype="&xsd;string">500mg twice daily</cds:dosage>
        <cds:treatsDisease rdf:resource="&cds;Type2Diabetes"/>
        <!--
            INFERENCE RULE 9 demo: SymmetricProperty interactsWith
            Metformin interactsWith Diazepam is stated here.
            The reasoner infers Diazepam interactsWith Metformin automatically.
        -->
        <cds:interactsWith rdf:resource="&cds;Diazepam"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;Aspirin">
        <rdf:type rdf:resource="&cds;Medication"/>
        <cds:medicationName rdf:datatype="&xsd;string">Aspirin</cds:medicationName>
        <cds:dosage rdf:datatype="&xsd;string">81mg daily</cds:dosage>
        <cds:treatsDisease rdf:resource="&cds;CoronaryArteryDisease"/>
        <!-- Contraindication: Aspirin should not be taken with Ibuprofen -->
        <cds:contraindicatedWith rdf:resource="&cds;Ibuprofen"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;Antihistamine">
        <rdf:type rdf:resource="&cds;Medication"/>
        <cds:medicationName rdf:datatype="&xsd;string">Antihistamine</cds:medicationName>
        <cds:dosage rdf:datatype="&xsd;string">10mg daily</cds:dosage>
        <cds:treatsDisease rdf:resource="&cds;AllergicReaction"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;Ibuprofen">
        <rdf:type rdf:resource="&cds;Medication"/>
        <cds:medicationName rdf:datatype="&xsd;string">Ibuprofen</cds:medicationName>
        <cds:dosage rdf:datatype="&xsd;string">400mg three times daily</cds:dosage>
        <cds:treatsDisease rdf:resource="&cds;RheumatoidArthritis"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;Sumatriptan">
        <rdf:type rdf:resource="&cds;Medication"/>
        <cds:medicationName rdf:datatype="&xsd;string">Sumatriptan</cds:medicationName>
        <cds:dosage rdf:datatype="&xsd;string">50mg as needed</cds:dosage>
        <cds:treatsDisease rdf:resource="&cds;Migraine"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;Penicillin">
        <rdf:type rdf:resource="&cds;Medication"/>
        <cds:medicationName rdf:datatype="&xsd;string">Penicillin</cds:medicationName>
        <cds:dosage rdf:datatype="&xsd;string">250mg four times daily</cds:dosage>
        <cds:treatsDisease rdf:resource="&cds;Tonsillitis"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&cds;Diazepam">
        <rdf:type rdf:resource="&cds;Medication"/>
        <cds:medicationName rdf:datatype="&xsd;string">Diazepam</cds:medicationName>
        <cds:dosage rdf:datatype="&xsd;string">5mg twice daily</cds:dosage>
        <cds:treatsDisease rdf:resource="&cds;AnxietyDisorder"/>
    </owl:NamedIndividual>

